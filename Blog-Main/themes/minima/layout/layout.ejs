<!DOCTYPE html>
<html lang="<%= config.language %>">

<head>

  <!-- Minima -->
  <!-- Hexo theme created by @adisaktijrs -->

  <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta charset="utf-8">

  <%
  if (!config.author) {
    config.author = '';
  }

  let title = config.title;
  if (is_archive()) {
    title = 'All Posts - ' + config.author;
  } else if (is_post()) {
    title = page.title;
  } else if (is_page()) {
    title = page.title + ' - ' + config.author;
  } else if (is_tag()) {
    title = 'Posts Related to ' + page.tag;
  }

  const cleanUrl = url.replace(/index\.html$/, '');
  let pageDescription = config.description || '';

  if (is_page() && page.description) {
    pageDescription = page.description;
  } else if (page.content) {
    const contentDescription = strip_html(page.content).replace(/\n/g, ' ').replace(/^\s*/, '').replace(/\s*$/, '');
    pageDescription = contentDescription.substring(0, 150);
    if (contentDescription.length > 150) {
      pageDescription += '...';
    }
  }

  let socialImage = '';
  if ((is_post() || is_page()) && page.thumbnail) {
    socialImage = config.url + page.thumbnail;
  } else if (theme.thumbnail) {
    socialImage = config.url + theme.thumbnail;
  }

  const isContentPage = is_post() || is_page();
  const ogType = isContentPage ? 'article' : 'website';
  %>
  <title><%= title %></title>
  <% if (config.sitemap) { %>
  <link rel="sitemap" href="<%-config.url + config.sitemap.path %>" />
  <% } %>
  <link rel="canonical" href="<%= cleanUrl %>">
  <meta name="description" content="<%= pageDescription %>">
  <meta name="title" content="<%= title %>">
  <% if (is_post() && page.tags && page.tags.length) { %>
    <% const pageTagNames = []; page.tags.each(function(tag){ pageTagNames.push(tag.name); }); %>
  <meta name="tag" content="<%- pageTagNames.join(', ') %>">
  <% } %>
  <% if (config.keywords && String(config.keywords).trim()) { %>
  <meta name="keywords" content="<%= config.keywords %>">
  <% } %>
  <meta name="author" content="<%- config.author %>">
  <% if (socialImage) { %>
  <meta property="og:image" content="<%- socialImage %>">
  <% } %>
  <meta property="og:site_name" content="<%= config.title %>" />
  <meta property="og:type" content="<%= ogType %>" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:url" content="<%= cleanUrl %>" />
  <% if (is_post() && page.tags && page.tags.length) { %>
    <% page.tags.each(function(tag){ %>
      <meta property="article:tag" content="<%- tag.name %>" />
    <% }) %>
  <% } %>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <% if (socialImage) { %>
  <meta name="twitter:image" content="<%- socialImage %>">
  <% } %>
  <meta name="twitter:url" content="<%= cleanUrl %>" />

  <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script>
    (function () {
      try {
        if (localStorage.getItem('preferredTheme') === 'dark') {
          document.documentElement.classList.add('darkmode');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.style.colorScheme = 'light';
        }
      } catch (e) {
        document.documentElement.style.colorScheme = 'light';
      }
    })();
  </script>
  <style>
    html { background: #fff; }
    html.darkmode { background: rgb(34, 34, 38); color: rgb(230, 230, 230); }
    html.darkmode body { background: rgb(34, 34, 38); color: rgb(230, 230, 230); }
  </style>

  <!-- Preload fonts
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="preload" href="/fonts/LXGWWenKaiLite-Medium.ttf" as="font" type="font/ttf" crossorigin media="(min-width: 769px)">

  <!-- CSS
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- css('css/normalize.css') %>
  <%- css('css/skeleton.css') %>
  <%- css('css/custom.css') %>
  <!-- User css -->
  <% if (theme.usercss) { %>
  <%- css(theme.usercss) %>
  <% } %>

  <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="icon" type="image/png" href="<%- theme.favicon %>">

  <!-- Custom Theme Color Style
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- partial('partial/tcolor') %>

  <script>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']],
        processEscapes: true,
        processEnvironments: true
      },
      svg: {
        fontCache: 'global'
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
      }
    };
  </script>
  <script src="/js/theme-config.js" defer></script>
  <% if (theme.picjs) { %>
  <script src="<%- theme.picjs %>" defer></script>
  <% } %>
  <script src="/js/navigation-init.js" defer></script>
  <script src="/js/media-init.js" defer></script>
  <script src="/js/math-init.js" defer></script>
  <script src="/js/mermaid-init.js" defer></script>
  <script src="/js/theme-toggle.js" defer></script>
  <% if (is_archive()) { %>
  <script src="/js/archive-search.js" defer></script>
  <% } %>
  <% if (is_post()) { %>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="dns-prefetch" href="//cdn.jsdelivr.net">
  <%- css('css/prism-dark.css') %>
  <%- css('css/prism-line-numbers.css') %>
  <script src="/js/code-tools.js" defer></script>
  <script src="/js/reveal-init.js" defer></script>
  <script src="/js/reading-progress.js" defer></script>
  <% } %>

</head>

<body>
  <div id="reading-progress" class="reading-progress" hidden aria-hidden="true"></div>
  <div class="site-backdrop" aria-hidden="true"></div>
  <div class="container">
    <div class="row">
      <div>

        <%- partial('partial/header') %>
        <div class="trans" id="page-content">
          <%- body %>
        </div>
        <%- partial('partial/footer') %>
      </div>

    </div>

  </div>
  <script src="/js/site-init.js" defer></script>

</body>

</html>
