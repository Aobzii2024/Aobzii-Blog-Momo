<%
  const mode = page.archive_mode === 'tag' ? 'tag' : 'time';
  const posts = site.posts.sort('date', 'desc');
  const monthGroups = {};
  const tagGroups = {};

  posts.forEach(function(post) {
    const monthKey = full_date(post.date, 'YYYY-MM');
    if (!monthGroups[monthKey]) {
      monthGroups[monthKey] = { label: full_date(post.date, 'YYYY.MM'), items: [] };
    }
    monthGroups[monthKey].items.push(post);

    if (post.tags && post.tags.length) {
      post.tags.each(function(tag) {
        if (!tagGroups[tag.name]) tagGroups[tag.name] = [];
        tagGroups[tag.name].push(post);
      });
    } else {
      if (!tagGroups['未分类标签']) tagGroups['未分类标签'] = [];
      tagGroups['未分类标签'].push(post);
    }
  });

  const monthKeys = Object.keys(monthGroups).sort().reverse();
  const tagKeys = Object.keys(tagGroups).sort(function(a, b){ return a.localeCompare(b); });
%>

<div class="archive-shell <%- mode === 'time' ? 'archive-shell-time' : '' %>">
  <h2>归档</h2>
  <div class="archive-switch">
    <a href="<%- url_for('/archives/') %>" class="archive-switch-link <%- mode === 'time' ? 'is-active' : '' %>">按时间</a>
    <a href="<%- url_for('/archives/tag/') %>" class="archive-switch-link <%- mode === 'tag' ? 'is-active' : '' %>">按标签</a>
  </div>

  <div class="post-search-wrap">
    <input id="archive-search-input" class="post-search-input" type="search" placeholder="按标题或标签搜索" aria-label="搜索归档">
  </div>

  <% if (mode === 'time') { %>
    <% monthKeys.forEach(function(key){ %>
      <section class="archive-group">
        <h3 class="archive-group-title"><%- monthGroups[key].label %></h3>
        <% monthGroups[key].items.forEach(function(post){ %>
          <%
            let archiveTagText = '';
            if (post.tags && post.tags.length) {
              post.tags.each(function(tag){ archiveTagText += ' ' + tag.name; });
            }
          %>
          <article class="archive-item" data-search="<%- ((post.title || '') + archiveTagText).toLowerCase() %>">
            <div class="archive-item-date"><%- full_date(post.date, 'MM-DD') %></div>
            <div class="archive-item-main">
              <div class="archive-item-title-row">
                <a href="<%- url_for(post.path) %>" class="interactive-link"><%- post.title || '未命名' %></a>
                <% if (post.tags && post.tags.length) { %>
                  <div class="archive-item-tags"><%- list_tags(post.tags, {class: 'archive-item-tag-list', show_count: false, style: false}) %></div>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </section>
    <% }) %>
  <% } else { %>
    <% tagKeys.forEach(function(tagName){ %>
      <section class="archive-group">
        <h3 class="archive-group-title"># <%- tagName %></h3>
        <% tagGroups[tagName].forEach(function(post){ %>
          <article class="archive-item" data-search="<%- ((post.title || '') + ' ' + tagName).toLowerCase() %>">
            <div class="archive-item-date"><%- full_date(post.date, 'YYYY-MM-DD') %></div>
            <div class="archive-item-main">
              <a href="<%- url_for(post.path) %>" class="interactive-link"><%- post.title || '未命名' %></a>
            </div>
          </article>
        <% }) %>
      </section>
    <% }) %>
  <% } %>
</div>
